# Database (Neon Postgres)
DATABASE_URL=postgresql://user:pass@host/dbname

# X API (via twitterapi.io)
X_API_KEY=your_twitterapi_io_key

# Auth.js
AUTH_SECRET=generate_with_openssl_rand_base64_32
